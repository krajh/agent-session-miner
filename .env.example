# Where notes are written (required for `mine`)
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Claude Code transcripts directory (primary source; default shown)
CLAUDE_PROJECTS_DIR=$HOME/.claude/projects

# OpenCode SQLite database (default shown; find with: find ~ -name opencode.db)
OPENCODE_DB_PATH=$HOME/.local/share/opencode/opencode.db

# Which sources to mine, comma-separated. Default: claude,opencode
# SOURCES=claude,opencode

# Date range. Default: last 30 days
# DAYS=30
# START_DATE=2026-06-01
# END_DATE=2026-06-30

# Weekly performance reflection template (default: <vault>/Templates/Weekly Performance Reflection.md)
# PERFORMANCE_TEMPLATE_PATH=/path/to/Templates/Weekly Performance Reflection.md
