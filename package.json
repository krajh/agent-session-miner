{
  "name": "agent-session-miner",
  "version": "2.0.0",
  "description": "Mine Claude Code and OpenCode sessions into Obsidian daily/weekly notes with parallel-aware time tracking",
  "main": "src/mine.ts",
  "scripts": {
    "mine": "bun run src/mine.ts",
    "calculate": "bun run src/mine.ts --calculate",
    "analyze": "bun run src/mine.ts --analyze",
    "setup:cron": "bash scripts/setup-cron.sh",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.0.0"
  },
  "keywords": [
    "claude-code",
    "opencode",
    "obsidian",
    "session-tracking",
    "time-tracking",
    "para-method",
    "ai-agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/krajh/agent-session-miner.git"
  }
}
